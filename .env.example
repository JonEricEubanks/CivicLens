# CivicLens Environment Configuration

# GitHub Models (primary LLM)
GITHUB_TOKEN=your_github_token_here

# MCP Server
MCP_PORT=3000

# API Server
API_PORT=7072

# Ollama (local embeddings for RAG)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Azure Cosmos DB (optional — enables cloud persistence)
# COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
# COSMOS_KEY=your-cosmos-primary-key

# SMTP Email (optional — enables real email notifications)
# Without these, confirmation emails are saved as local HTML previews only.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# EMAIL_FROM="CivicLens" <noreply@example.com>
